{
	"name": "astro-loader-github-repos",
	"version": "1.1.0",
	"description": "Load GitHub repository data into the Astro content layer",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"keywords": [
		"astro",
		"withastro",
		"astro-loader",
		"github"
	],
	"author": "Connor Bär <github@connorbaer.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/connor-baer/astro-loader-github-repos.git"
	},
	"homepage": "https://github.com/connor-baer/astro-loader-github-repos#readme",
	"files": [
		"dist",
		"README.md",
		"LICENSE.md"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"lint": "biome check --write",
		"lint:ci": "biome ci",
		"prerelease": "npm run build",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"astro": "^6.1.1",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"astro": "^4.14.0 || ^5.0.0 || ^6.0.0"
	},
	"dependencies": {
		"octokit": "^5.0.5"
	}
}
